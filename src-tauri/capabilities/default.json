{
  "identifier": "default",
  "description": "Default capabilities for FastCoin",
  "windows": ["main", "*"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:scope-app-recursive",
    "fs:allow-read-text-file",
    "fs:allow-read-file",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "fs:allow-remove"
  ]
}
